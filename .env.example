# API Keys
VNSTOCK_API_KEY=your_vnstock_api_key
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Admin Chat ID (for /grant command)
ADMIN_CHAT_ID=your_admin_chat_id

# Google OAuth 2.0 for Gemini AI (Login with Google)
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth client ID -> Desktop app
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret

# Bank Info for payment
BANK_NAME=YourBank
BANK_BIN=970xxx
BANK_ACCOUNT=your_account_number
BANK_OWNER=YOUR_NAME

# Subscription Coupons (format: CODE:DISCOUNT:EXPIRES_AT:MAX_USES)
COUPONS=NEWUSER:20000:2025-12-31:100
